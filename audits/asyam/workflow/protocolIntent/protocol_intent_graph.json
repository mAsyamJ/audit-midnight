{
  "protocol": "Morpho Midnight",
  "version": "2026-05-30",
  "components": [
    {"id": "Midnight", "role": "core", "files": ["src/Midnight.sol"]},
    {"id": "MidnightBundles", "role": "periphery", "files": ["src/periphery/MidnightBundles.sol"]},
