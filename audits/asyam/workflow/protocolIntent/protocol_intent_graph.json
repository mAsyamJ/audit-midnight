    {"id": "SetterRatifier", "role": "ratifier", "files": ["src/ratifiers/SetterRatifier.sol"]},
    {"id": "TakeAmountsLib", "role": "math", "files": ["src/periphery/TakeAmountsLib.sol"]},
    {"id": "ConsumableUnitsLib", "role": "math", "files": ["src/periphery/ConsumableUnitsLib.sol"]},
    {"id": "IdLib", "role": "library", "files": ["src/libraries/IdLib.sol"]},
    {"id": "TickLib", "role": "library", "files": ["src/libraries/TickLib.sol"]}
  ],
  "actors": [
    {"id": "lender", "goals": ["earn fixed rate", "withdraw credit"]},
    {"id": "borrower", "goals": ["borrow against collateral", "repay or get liquidated"]},
    {"id": "maker", "goals": ["quote without escrow"]},
    {"id": "taker", "goals": ["execute offers"]},
    {"id": "liquidator", "goals": ["seize collateral profitably"]},
    {"id": "market_creator", "goals": ["define oracle gates collateral"]},
    {"id": "delegate", "goals": ["operate on behalf of maker"]},
    {"id": "callback", "goals": ["provide liquidity at settlement"], "trusted": false}
  ],
  "assets": [
    {"id": "loan_token", "flows": ["take", "repay", "withdraw", "liquidate", "flashLoan"]},
    {"id": "collateral_token", "flows": ["supplyCollateral", "withdrawCollateral", "liquidate"]},
    {"id": "credit_units", "flows": ["take", "withdraw", "updatePosition"]},
    {"id": "debt_units", "flows": ["take", "repay", "liquidate"]}
  ],
  "economic_flows": [
    {"id": "flow_take", "from": "payer", "to": ["midnight", "receiver"], "function": "take"},
    {"id": "flow_repay", "from": "payer", "to": "midnight", "function": "repay"},
    {"id": "flow_withdraw", "from": "midnight", "to": "receiver", "function": "withdraw"},
    {"id": "flow_liquidate_collateral", "from": "midnight", "to": "receiver", "function": "liquidate"},
    {"id": "flow_liquidate_repay", "from": "payer", "to": "midnight", "function": "liquidate"},
    {"id": "flow_bundle_buy", "from": "router_user", "to": "midnight_via_take", "function": "MidnightBundles.buy"}
  ],
  "trust_boundaries": [
    {"id": "TB-001", "boundary": "core_to_callback", "trusted": "protocol", "untrusted": "callback_code"},
    {"id": "TB-002", "boundary": "core_to_token", "trusted": "protocol", "untrusted": "erc20_behavior", "assumption": "exact_non_reentrant"},
    {"id": "TB-003", "boundary": "core_to_oracle", "trusted": "market_creator", "untrusted": "price"},
    {"id": "TB-004", "boundary": "periphery_to_midnight", "trusted": "router", "untrusted": "calldata"}
  ],
